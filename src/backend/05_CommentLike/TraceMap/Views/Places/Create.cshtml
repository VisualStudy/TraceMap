@model TracePlace
@{
    ViewData["Title"] = "새 장소 추가";
}
<header class="page-header with-back">
    <a asp-action="Index">‹</a>
    <div>
        <h1>새 장소 추가</h1>
        <p>장소 이름, 카테고리, 설명, 방문 여부, 위치 정보를 입력합니다.</p>
    </div>
</header>
<form asp-action="Create" method="post" class="edit-form">
    <partial name="_Form" model="Model" />
    <button class="primary-button full" type="submit">저장하기</button>
    <a class="outline-button full" asp-action="Index">취소</a>
</form>
