@model TracePlace
@{
    ViewData["Title"] = "장소 상세 정보";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}
<header class="page-header with-back">
    <a asp-action="Index">‹</a>
    <div>
        <h1>장소 상세 정보</h1>
        <p>장소 기록, 방문 체크, 수정, 삭제, 좋아요와 댓글을 한 화면에서 테스트합니다.</p>
    </div>
</header>

<section class="detail-panel">
    <dl>
        <dt>📍 장소</dt><dd>@Model.Name</dd>
        <dt>🏷 카테고리</dt><dd>@Model.Category</dd>
        <dt>📝 설명</dt><dd>@Model.Description</dd>
        <dt>🏃 추천 활동</dt><dd>@Model.RecommendedActivities</dd>
        <dt>📅 방문 여부</dt><dd>@(Model.IsVisited ? "완료" : "예정")</dd>
        <dt>📊 방문 횟수</dt><dd>@Model.VisitCount 회</dd>
        <dt>🗺 위치</dt><dd>@Model.Latitude, @Model.Longitude</dd>
        <dt>★ 공유 여부</dt><dd>@(Model.IsShared ? "공유 가능" : "개인 기록")</dd>
    </dl>
</section>

<section class="actions">
@if (!Model.IsVisited)
{
    <form asp-action="MarkVisited" asp-route-id="@Model.Id" method="post">
        <button class="primary-button full" type="submit">방문 완료로 변경</button>
    </form>
}
else
{
    <form asp-action="AddVisit" asp-route-id="@Model.Id" method="post">
        <button class="primary-button full" type="submit">방문 횟수 +1</button>
    </form>
    <form asp-action="RemoveVisit" asp-route-id="@Model.Id" method="post">
        <button class="outline-button full" type="submit">방문 횟수 -1</button>
    </form>
}
    <div class="two-buttons">
        <a class="outline-button" asp-action="Edit" asp-route-id="@Model.Id">✎ 수정하기</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('정말 삭제하시겠습니까? 목록과 지도에서 함께 제거됩니다.');">
            <button class="danger-button" type="submit">🗑 삭제하기</button>
        </form>
    </div>
    <a class="outline-button full" asp-controller="Map" asp-action="Index" asp-route-selectedId="@Model.Id">지도에서 보기</a>
</section>

<section class="social-panel" id="place-social-panel" data-place-id="@Model.Id" data-is-authenticated="@(isAuthenticated ? "true" : "false")">
    <div class="social-header">
        <div>
            <h2>좋아요와 댓글</h2>
            <p>이 장소에 대한 반응을 남길 수 있습니다.</p>
        </div>
        <button id="like-button" class="outline-button" type="button" @(isAuthenticated ? null : "disabled")>
            ♡ 좋아요 <span id="like-count">0</span>
        </button>
    </div>

    @if (isAuthenticated)
    {
        <div class="comment-form">
            <textarea id="comment-content" rows="3" maxlength="500" placeholder="이 장소에 대한 댓글을 입력하세요."></textarea>
            <button id="comment-submit" class="primary-button full" type="button">댓글 등록</button>
        </div>
    }
    else
    {
        <div class="login-guide">
            좋아요와 댓글은 로그인한 사용자만 사용할 수 있습니다.
            <a asp-controller="Account" asp-action="Login">로그인하기</a>
        </div>
    }

    <div id="social-message" class="social-message" hidden></div>
    <div id="comment-list" class="comment-list"></div>
</section>

<script>
(function () {
    const panel = document.getElementById('place-social-panel');
    if (!panel) return;

    const placeId = panel.dataset.placeId;
    const isAuthenticated = panel.dataset.isAuthenticated === 'true';
    const socialUrl = `/api/places/${placeId}/social`;
    const likeUrl = `/api/places/${placeId}/like`;
    const commentsUrl = `/api/places/${placeId}/comments`;

    const likeButton = document.getElementById('like-button');
    const likeCount = document.getElementById('like-count');
    const commentContent = document.getElementById('comment-content');
    const commentSubmit = document.getElementById('comment-submit');
    const commentList = document.getElementById('comment-list');
    const messageBox = document.getElementById('social-message');

    function showMessage(text, isError) {
        if (!messageBox) return;
        messageBox.textContent = text;
        messageBox.hidden = false;
        messageBox.className = isError ? 'social-message error' : 'social-message';
    }

    function clearMessage() {
        if (!messageBox) return;
        messageBox.hidden = true;
        messageBox.textContent = '';
    }

    function escapeHtml(value) {
        return (value ?? '').toString()
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function formatDate(value) {
        if (!value) return '';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '';
        return date.toLocaleString('ko-KR');
    }

    function renderSocial(data) {
        likeCount.textContent = data.likeCount ?? 0;

        if (likeButton) {
            likeButton.innerHTML = `${data.likedByMe ? '♥' : '♡'} 좋아요 <span id="like-count">${data.likeCount ?? 0}</span>`;
            likeButton.classList.toggle('liked', !!data.likedByMe);
        }

        const comments = data.comments ?? [];
        if (comments.length === 0) {
            commentList.innerHTML = '<p class="empty-comments">아직 등록된 댓글이 없습니다.</p>';
            return;
        }

        commentList.innerHTML = comments.map(comment => `
            <article class="comment-item">
                <div class="comment-meta">
                    <strong>${escapeHtml(comment.userName)}</strong>
                    <span>${formatDate(comment.createdAt)}</span>
                </div>
                <p>${escapeHtml(comment.content)}</p>
            </article>
        `).join('');
    }

    async function loadSocial() {
        try {
            const response = await fetch(socialUrl, { credentials: 'same-origin' });
            if (!response.ok) throw new Error('social-load-failed');
            const data = await response.json();
            renderSocial(data);
        } catch {
            showMessage('좋아요와 댓글 정보를 불러오지 못했습니다.', true);
        }
    }

    if (likeButton && isAuthenticated) {
        likeButton.addEventListener('click', async function () {
            clearMessage();
            likeButton.disabled = true;
            try {
                const response = await fetch(likeUrl, {
                    method: 'POST',
                    credentials: 'same-origin'
                });
                if (!response.ok) throw new Error('like-failed');
                const data = await response.json();
                renderSocial(data);
            } catch {
                showMessage('좋아요 처리 중 오류가 발생했습니다.', true);
            } finally {
                likeButton.disabled = false;
            }
        });
    }

    if (commentSubmit && commentContent && isAuthenticated) {
        commentSubmit.addEventListener('click', async function () {
            clearMessage();
            const content = commentContent.value.trim();
            if (!content) {
                showMessage('댓글 내용을 입력하세요.', true);
                commentContent.focus();
                return;
            }

            commentSubmit.disabled = true;
            try {
                const response = await fetch(commentsUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ content })
                });
                if (!response.ok) throw new Error('comment-failed');
                const data = await response.json();
                commentContent.value = '';
                renderSocial(data);
                showMessage('댓글이 등록되었습니다.', false);
            } catch {
                showMessage('댓글 등록 중 오류가 발생했습니다.', true);
            } finally {
                commentSubmit.disabled = false;
            }
        });
    }

    loadSocial();
})();
</script>
