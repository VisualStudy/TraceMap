@using TraceMap.Models
@{
    ViewData["Title"] = "홈";
    var pages = ViewBag.Pages as IReadOnlyList<TracePage> ?? [];
    var places = ViewBag.Places as IReadOnlyList<TracePlace> ?? [];
    var challenges = ViewBag.Challenges as IReadOnlyList<ChallengeStatus> ?? [];
    var completed = challenges.Count(c => c.IsCompleted);
}
<section class="home-hero">
    <div class="pin-logo">📍</div>
    <h1>TraceMap</h1>
    <p>나의 발자취를 지도에 남기다</p>
</section>

<section class="stats-grid">
    <div><strong>@places.Count</strong><span>기록 장소</span></div>
    <div><strong>@places.Count(p => p.IsVisited)</strong><span>방문 완료</span></div>
    <div><strong>@completed/@challenges.Count</strong><span>도전과제</span></div>
</section>

<section class="menu-list">
    <a class="menu-card" asp-controller="Map" asp-action="Index"><span>🗺</span><strong>지도에서 스팟 보기</strong><em>›</em></a>
    <a class="menu-card" asp-controller="Places" asp-action="Index"><span>☰</span><strong>내 장소 목록 보기</strong><em>›</em></a>
    <a class="menu-card" asp-controller="Challenges" asp-action="Index"><span>🏆</span><strong>도전과제 확인하기</strong><em>›</em></a>
    <a class="menu-card" asp-controller="Recommendations" asp-action="Index"><span>★</span><strong>추천 스팟 보기</strong><em>›</em></a>
</section>

<section class="guide-card">
    <h2>전체 흐름 테스트</h2>
    <p>홈 → 지도/목록/도전/추천 → 장소 상세 → 방문 체크, 수정, 삭제, 저장 흐름을 MVC 화면으로 먼저 검증할 수 있습니다.</p>
    <a asp-controller="Places" asp-action="Create" class="primary-link">+ 새 장소 추가</a>
</section>
