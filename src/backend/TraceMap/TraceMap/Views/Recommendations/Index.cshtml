@model IReadOnlyList<TracePlace>
@{
    ViewData["Title"] = "추천 스팟";
}
<header class="page-header">
    <h1>추천 스팟</h1>
    <p>다른 사용자와 비회원에게 공개되는 공유 장소 목록입니다.</p>
</header>

<section class="cards">
@foreach (var place in Model)
{
    <article class="place-card recommendation">
        <div class="card-top">
            <h2>@place.Name</h2>
            <span class="badge">@place.Category</span>
        </div>
        <p>@(string.IsNullOrWhiteSpace(place.SharedDescription) ? place.Description : place.SharedDescription)</p>
        <div class="meta-row social-count-row">
            <span>좋아요: <strong>@place.LikeCount</strong></span>
            <span>댓글: <strong>@place.CommentCount</strong></span>
        </div>
        <a class="small-button" asp-controller="Places" asp-action="Details" asp-route-id="@place.Id">상세 보기</a>
    </article>
}
</section>
