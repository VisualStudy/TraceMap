@model TracePlace
@{
    ViewData["Title"] = "장소 수정";
}
<header class="page-header with-back">
    <a asp-action="Details" asp-route-id="@Model.Id">‹</a>
    <div>
        <h1>장소 수정</h1>
        <p>기존 장소 정보를 불러온 뒤 수정합니다.</p>
    </div>
</header>
<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="edit-form">
    <input type="hidden" asp-for="Id" />
    <partial name="_Form" model="Model" />
    <button class="primary-button full" type="submit">수정 저장</button>
    <a class="outline-button full" asp-action="Details" asp-route-id="@Model.Id">취소</a>
</form>
