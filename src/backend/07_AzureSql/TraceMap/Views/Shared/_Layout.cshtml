<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - TraceMap</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <div class="phone-shell">
        <main class="screen">
            <header class="top-auth-bar">
                <a class="brand-link" asp-controller="Home" asp-action="Index">📍 TraceMap</a>
                <div class="auth-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Account" asp-action="Profile" title="회원정보">👤 @User.Identity.Name</a>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit">로그아웃</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login">로그인</a>
                        <a asp-controller="Account" asp-action="Register">회원가입</a>
                    }
                </div>
            </header>
            @if (TempData["Message"] is string message)
            {
                <div class="toast">@message</div>
            }
            @RenderBody()
            <nav class="bottom-nav">
                <a asp-controller="Home" asp-action="Index">⌂<span>홈</span></a>
                <a asp-controller="Map" asp-action="Index">🗺<span>지도</span></a>
                <a asp-controller="Places" asp-action="Index">☰<span>목록</span></a>
                <a asp-controller="Challenges" asp-action="Index">🏆<span>도전</span></a>
            </nav>
        </main>
    </div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
