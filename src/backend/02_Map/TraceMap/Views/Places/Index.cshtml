@model IReadOnlyList<TracePlace>
@{
    ViewData["Title"] = "내 장소 목록";
}
<header class="page-header">
    <h1>내 장소 목록</h1>
    <p>장소명, 카테고리, 설명, 방문 여부를 카드로 확인합니다.</p>
</header>
<a class="outline-button full" asp-action="Create">+ 새 장소 추가</a>

<section class="cards">
@foreach (var place in Model)
{
    <article class="place-card">
        <div class="card-top">
            <h2>@place.Name</h2>
            <span class="badge">@place.Category</span>
        </div>
        <p>@place.Description</p>
        <div class="meta-row">
            <span>방문 여부: <strong>@(place.IsVisited ? "완료" : "예정")</strong></span>
            <span>방문 횟수: <strong>@place.VisitCount</strong></span>
        </div>
        <a class="small-button" asp-action="Details" asp-route-id="@place.Id">상세 보기</a>
    </article>
}
</section>
