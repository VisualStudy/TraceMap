@model TracePlace
@{
    ViewData["Title"] = "장소 상세 정보";
}
<header class="page-header with-back">
    <a asp-action="Index">‹</a>
    <div>
        <h1>장소 상세 정보</h1>
        <p>장소 기록, 방문 체크, 수정, 삭제를 한 화면에서 테스트합니다.</p>
    </div>
</header>

<section class="detail-panel">
    <dl>
        <dt>📍 장소</dt><dd>@Model.Name</dd>
        <dt>🏷 카테고리</dt><dd>@Model.Category</dd>
        <dt>📝 설명</dt><dd>@Model.Description</dd>
        <dt>🏃 추천 활동</dt><dd>@Model.RecommendedActivities</dd>
        <dt>📅 방문 여부</dt><dd>@(Model.IsVisited ? "완료" : "예정")</dd>
        <dt>📊 방문 횟수</dt><dd>@Model.VisitCount 회</dd>
        <dt>🗺 위치</dt><dd>@Model.Latitude, @Model.Longitude</dd>
        <dt>★ 공유 여부</dt><dd>@(Model.IsShared ? "공유 가능" : "개인 기록")</dd>
    </dl>
</section>

<section class="actions">
@if (!Model.IsVisited)
{
    <form asp-action="MarkVisited" asp-route-id="@Model.Id" method="post">
        <button class="primary-button full" type="submit">방문 완료로 변경</button>
    </form>
}
else
{
    <form asp-action="AddVisit" asp-route-id="@Model.Id" method="post">
        <button class="primary-button full" type="submit">방문 횟수 +1</button>
    </form>
    <form asp-action="RemoveVisit" asp-route-id="@Model.Id" method="post">
        <button class="outline-button full" type="submit">방문 횟수 -1</button>
    </form>
}
    <div class="two-buttons">
        <a class="outline-button" asp-action="Edit" asp-route-id="@Model.Id">✎ 수정하기</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('정말 삭제하시겠습니까? 목록과 지도에서 함께 제거됩니다.');">
            <button class="danger-button" type="submit">🗑 삭제하기</button>
        </form>
    </div>
    <a class="outline-button full" asp-controller="Map" asp-action="Index" asp-route-selectedId="@Model.Id">지도에서 보기</a>
</section>
